'use client';

import React, { createContext, useContext, useState, useEffect, ReactNode } from 'react';
import {
  authService,
  employeeService,
  attendanceService,
  monthlyActivitiesService,
  bookmarkService,
  readingHistoryService
} from '@/services/dataService';
import { Employee } from '@/types';
import { supabase } from '@/services/dataService';

interface AppContextType {
  currentUser: Employee | null;
  attendance: Record<string, any>;
  monthlyActivities: Record<string, any>;
  bookmarks: any[];
  readingHistory: any[];
  loading: boolean;
  error: string | null;
  signIn: (email: string, password: string) => Promise<void>;
  signOut: () => Promise<void>;
  updateProfile: (updates: Partial<Employee>) => Promise<void>;
  submitAttendance: (
    entityId: string,
    status: 'hadir' | 'tidak-hadir',
    reason?: string | null,
    isLateEntry?: boolean,
    location?: { latitude: number; longitude: number }
  ) => Promise<void>;
  updateMonthlyActivity: (monthKey: string, dayKey: string, activityId: string, value: boolean) => Promise<void>;
  toggleBookmark: (bookmarkData: any) => Promise<void>;
  addReadingHistory: (history: { book_title: string; pages_read: string; date_completed: string }) => Promise<void>;
  deleteReadingHistory: (historyId: string) => Promise<void>;
}

const AppContext = createContext<AppContextType | undefined>(undefined);

export const useAppContext = () => {
  const context = useContext(AppContext);
  if (!context) {
    throw new Error('useAppContext must be used within an AppProvider');
  }
  return context;
};

interface AppProviderProps {
  children: ReactNode;
}

export const AppProvider: React.FC<AppProviderProps> = ({ children }) => {
  const [currentUser, setCurrentUser] = useState<Employee | null>(null);
  const [attendance, setAttendance] = useState<Record<string, any>>({});
  const [monthlyActivities, setMonthlyActivities] = useState<Record<string, any>>({});
  const [bookmarks, setBookmarks] = useState<any[]>([]);
  const [readingHistory, setReadingHistory] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  // Initialize data when user logs in
  const initializeUserData = async (user: Employee) => {
    try {
      setLoading(true);
      setError(null);

      // Fetch all related data
      const [
        attendanceData,
        activitiesData,
        bookmarksData,
        historyData
      ] = await Promise.all([
        attendanceService.getEmployeeAttendance(user.id),
        monthlyActivitiesService.getMonthlyActivities(user.id),
        bookmarkService.getBookmarks(user.id),
        readingHistoryService.getReadingHistory(user.id)
      ]);

      setAttendance(attendanceData);
      setMonthlyActivities(activitiesData);
      setBookmarks(bookmarksData);
      setReadingHistory(historyData);
    } catch (err) {
      console.error('Error initializing user data:', err);
      setError('Gagal memuat data pengguna');
    } finally {
      setLoading(false);
    }
  };

  // Check if user is already logged in on app start
  useEffect(() => {
    const checkSession = async () => {
      try {
        // Only check Supabase Auth session, don't auto-login
        const session = await authService.getCurrentSession();
        if (session?.user) {
          // Get user profile from employees table
          const user = await employeeService.getEmployee(session.user.id);
          setCurrentUser(user);
          await initializeUserData(user);
        }
      } catch (err) {
        console.error('No active session or error:', err);
      } finally {
        setLoading(false);
      }
    };

    checkSession();

    // NOTE: Auth listener disabled to prevent conflicts with custom login (LoginContainer)
    // LoginContainer uses direct database queries instead of Supabase Auth
    // If you want to use Supabase Auth in the future, uncomment the listener below

    // // Set up auth listener for sign in/sign out events
    // const { data: { subscription } } = supabase.auth.onAuthStateChange(
    //   async (event, session) => {
    //     if (event === 'SIGNED_IN' && session?.user) {
    //       try {
    //         const user = await employeeService.getEmployee(session.user.id);
    //         setCurrentUser(user);
    //         await initializeUserData(user);
    //       } catch (err) {
    //         setError('Gagal memuat data pengguna');
    //       }
    //     } else if (event === 'SIGNED_OUT') {
    //       setCurrentUser(null);
    //       setAttendance({});
    //       setMonthlyActivities({});
    //       setBookmarks([]);
    //       setReadingHistory([]);
    //     }
    //   }
    // );

    // return () => {
    //   subscription.unsubscribe();
    // };
  }, []);

  const signIn = async (email: string, password: string) => {
    try {
      setLoading(true);
      setError(null);

      await authService.signIn(email, password);
      // The auth state change listener will handle updating the user state
    } catch (err: any) {
      setError(err.message || 'Gagal masuk');
      throw err;
    } finally {
      setLoading(false);
    }
  };

  const signOut = async () => {
    try {
      setLoading(true);
      await authService.signOut();
      // The auth state change listener will handle clearing the user state
    } catch (err: any) {
      setError(err.message || 'Gagal keluar');
      throw err;
    } finally {
      setLoading(false);
    }
  };

  const updateProfile = async (updates: Partial<Employee>) => {
    if (!currentUser) throw new Error('No user logged in');

    try {
      const updatedUser = await authService.updateUserProfile(updates);
      setCurrentUser(updatedUser as Employee);
    } catch (err: any) {
      setError(err.message || 'Gagal memperbarui profil');
      throw err;
    }
  };

  const submitAttendance = async (
    entityId: string,
    status: 'hadir' | 'tidak-hadir',
    reason: string | null = null,
    isLateEntry: boolean = false,
    location?: { latitude: number; longitude: number }
  ) => {
    if (!currentUser) throw new Error('No user logged in');

    try {
      const record = await attendanceService.submitAttendance(
        currentUser.id,
        entityId,
        status,
        reason,
        isLateEntry,
        location
      );

      // Update local state
      setAttendance(prev => ({
        ...prev,
        [entityId]: {
          status,
          reason,
          timestamp: new Date(record.timestamp).getTime(),
          submitted: true,
          isLateEntry,
          location
        }
      }));
    } catch (err: any) {
      setError(err.message || 'Gagal menyimpan presensi');
      throw err;
    }
  };

  const updateMonthlyActivity = async (monthKey: string, dayKey: string, activityId: string, value: boolean) => {
    if (!currentUser) throw new Error('No user logged in');

    try {
      const updatedActivities = await monthlyActivitiesService.updateDayActivities(
        currentUser.id,
        monthKey,
        dayKey,
        { [activityId]: value }
      );

      setMonthlyActivities(updatedActivities);
    } catch (err: any) {
      setError(err.message || 'Gagal memperbarui aktivitas bulanan');
      throw err;
    }
  };

  const toggleBookmark = async (bookmarkData: any) => {
    if (!currentUser) throw new Error('No user logged in');

    try {
      // Check if bookmark already exists
      const existingBookmark = bookmarks.find(
        (b: any) => b.surahNumber === bookmarkData.surahNumber && b.ayahNumber === bookmarkData.ayahNumber
      );

      if (existingBookmark) {
        // Remove bookmark
        await bookmarkService.removeBookmark(existingBookmark.id);
        setBookmarks(prev => prev.filter((b: any) => b.id !== existingBookmark.id));
      } else {
        // Add bookmark
        const newBookmark = await bookmarkService.addBookmark(bookmarkData);
        setBookmarks(prev => [newBookmark, ...prev]);
      }
    } catch (err: any) {
      setError(err.message || 'Gagal mengelola bookmark');
      throw err;
    }
  };

  const addReadingHistory = async (history: { book_title: string; pages_read: string; date_completed: string }) => {
    if (!currentUser) throw new Error('No user logged in');

    try {
      const newHistory = await readingHistoryService.addReadingHistory(currentUser.id, history);
      setReadingHistory(prev => [newHistory, ...prev]);
    } catch (err: any) {
      setError(err.message || 'Gagal menambahkan riwayat bacaan');
      throw err;
    }
  };

  const deleteReadingHistory = async (historyId: string) => {
    try {
      await readingHistoryService.deleteReadingHistory(historyId);
      setReadingHistory(prev => prev.filter((h: any) => h.id !== historyId));
    } catch (err: any) {
      setError(err.message || 'Gagal menghapus riwayat bacaan');
      throw err;
    }
  };

  const value = {
    currentUser,
    attendance,
    monthlyActivities,
    bookmarks,
    readingHistory,
    loading,
    error,
    signIn,
    signOut,
    updateProfile,
    submitAttendance,
    updateMonthlyActivity,
    toggleBookmark,
    addReadingHistory,
    deleteReadingHistory
  };

  return (
    <AppContext.Provider value={value}>
      {children}
    </AppContext.Provider>
  );
};